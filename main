#include <Arduino.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#include <driver/i2s.h>

// --- Pines del micrófono I2S (INMP441) ---
#define I2S_WS 4
#define I2S_BCK 5
#define I2S_SD 6
#define I2S_PORT I2S_NUM_0

// --- Pines de la Pantalla OLED I2C ---
#define OLED_SDA 8
#define OLED_SCL 9
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1

Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

// --- Buffers y Sincronización (FreeRTOS) ---
#define BUFFER_SIZE 512 
int32_t i2s_buffer[BUFFER_SIZE];
int16_t display_buffer[SCREEN_WIDTH]; // Buffer para los 128 píxeles de la pantalla

// Semáforo para que la pantalla no lea el buffer mientras el micrófono lo está escribiendo
SemaphoreHandle_t audioMutex;

// Tareas para los núcleos
TaskHandle_t AudioTask;
TaskHandle_t DisplayTask;

// Función de configuración del I2S
void configure_i2s() {
    const i2s_config_t i2s_config = {
        .mode = (i2s_mode_t)(I2S_MODE_MASTER | I2S_MODE_RX),
        .sample_rate = 16000,
        .bits_per_sample = I2S_BITS_PER_SAMPLE_32BIT,
        .channel_format = I2S_CHANNEL_FMT_ONLY_LEFT,
        .communication_format = I2S_COMM_FORMAT_STAND_I2S,
        .intr_alloc_flags = ESP_INTR_FLAG_LEVEL1,
        .dma_buf_count = 4,
        .dma_buf_len = BUFFER_SIZE,
        .use_apll = false
    };

    const i2s_pin_config_t pin_config = {
        .bck_io_num = I2S_BCK,
        .ws_io_num = I2S_WS,
        .data_out_num = I2S_PIN_NO_CHANGE,
        .data_in_num = I2S_SD
    };

    i2s_driver_install(I2S_PORT, &i2s_config, 0, NULL);
    i2s_set_pin(I2S_PORT, &pin_config);
    i2s_start(I2S_PORT);
}

// ========================================================
// NÚCLEO 0: Tarea de lectura del Micrófono (Tiempo Real)
// ========================================================
void readAudioTask(void *pvParameters) {
    configure_i2s();
    size_t bytesRead = 0;

    while (true) {
        // Leemos datos crudos usando DMA (no bloquea el procesador)
        esp_err_t result = i2s_read(I2S_PORT, &i2s_buffer, sizeof(i2s_buffer), &bytesRead, portMAX_DELAY);

        if (result == ESP_OK && bytesRead > 0) {
            // Solicitamos el semáforo para actualizar el buffer de la pantalla de forma segura
            if (xSemaphoreTake(audioMutex, portMAX_DELAY)) {
                
                // Mapeamos las muestras del bloque al ancho de la pantalla (128 pixeles)
                int step = (bytesRead / sizeof(int32_t)) / SCREEN_WIDTH;
                if (step == 0) step = 1;

                for (int i = 0; i < SCREEN_WIDTH; i++) {
                    int32_t raw_sample = i2s_buffer[i * step] >> 14; 
                    display_buffer[i] = raw_sample;
                }
                
                xSemaphoreGive(audioMutex); // Liberamos el semáforo
            }
        }
        vTaskDelay(pdMS_TO_TICKS(5)); // Pausa mínima para no saturar el Watchdog
    }
}

// ========================================================
// NÚCLEO 1: Tarea de dibujado en la Pantalla OLED
// ========================================================
void drawDisplayTask(void *pvParameters) {
    // Inicializamos el bus I2C en los pines que hemos elegido
    Wire.begin(OLED_SDA, OLED_SCL);
    if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
        Serial.println("Fallo al iniciar la OLED");
        while (true) vTaskDelay(100);
    }
    
    display.clearDisplay();
    display.setTextColor(WHITE);
    display.setTextSize(1);
    
    while (true) {
        display.clearDisplay();
        
        // Interfaz fija
        display.setCursor(0, 0);
        display.print("Ronquidos C05 - Mic");
        display.drawLine(0, 10, SCREEN_WIDTH, 10, WHITE);
        
        // Línea central de silencio
        int center_y = 12 + (SCREEN_HEIGHT - 12) / 2;
        for(int i=0; i<SCREEN_WIDTH; i+=4) display.drawPixel(i, center_y, WHITE); 

        // Solicitamos el semáforo para leer el buffer sin que cambie a la mitad
        if (xSemaphoreTake(audioMutex, portMAX_DELAY)) {
            
            // Auto-escala dinámica del volumen (evita que la onda se salga de la pantalla)
            int32_t max_val = 100; // Sensibilidad base
            for (int i = 0; i < SCREEN_WIDTH; i++) {
                if (abs(display_buffer[i]) > max_val) {
                    max_val = abs(display_buffer[i]);
                }
            }

            // Dibujar la onda conectando puntos
            for (int i = 0; i < SCREEN_WIDTH - 1; i++) {
                int y1 = map(display_buffer[i], -max_val, max_val, SCREEN_HEIGHT - 1, 12);
                int y2 = map(display_buffer[i+1], -max_val, max_val, SCREEN_HEIGHT - 1, 12);
                
                // Restringimos para que no invada la zona del título
                y1 = constrain(y1, 12, SCREEN_HEIGHT - 1);
                y2 = constrain(y2, 12, SCREEN_HEIGHT - 1);

                display.drawLine(i, y1, i + 1, y2, WHITE);
            }
            
            xSemaphoreGive(audioMutex); // Liberamos el semáforo
        }
        
        display.display();
        
        // Tasa de refresco visual: 30 FPS para no saturar el bus I2C de la pantalla
        vTaskDelay(pdMS_TO_TICKS(33)); 
    }
}

void setup() {
    Serial.begin(115200);
    
    // Creamos el semáforo de sincronización entre núcleos
    audioMutex = xSemaphoreCreateMutex();

    // 1. Asignamos la captura de audio al NÚCLEO 0 (Prioridad máxima)
    xTaskCreatePinnedToCore(
        readAudioTask,   
        "AudioTask",     
        10000,           
        NULL,            
        2,               // Prioridad alta
        &AudioTask,      
        0                // NÚCLEO 0
    );

    // 2. Asignamos la pantalla al NÚCLEO 1 (Prioridad normal)
    xTaskCreatePinnedToCore(
        drawDisplayTask, 
        "DisplayTask",   
        10000,           
        NULL,            
        1,               // Prioridad normal
        &DisplayTask,    
        1                // NÚCLEO 1
    );
}

void loop() {
    // Al usar FreeRTOS con los dos núcleos, el loop principal de Arduino se queda libre.
    // Lo eliminamos para ahorrar memoria.
    vTaskDelete(NULL);
}
